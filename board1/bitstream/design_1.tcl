  # Create instance: rst_ps7_0_80M, and set properties
  set rst_ps7_0_80M [ create_bd_cell -type ip -vlnv xilinx.com:ip:proc_sys_reset:5.0 rst_ps7_0_80M ]

  # Create instance: yuyv_unpack, and set properties
  set block_name yuyv_unpack
  set block_cell_name yuyv_unpack
  if { [catch {set yuyv_unpack [create_bd_cell -type module -reference $block_name $block_cell_name] } errmsg] } {
